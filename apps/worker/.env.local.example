RUNTIME_MODE=local
STORAGE_PATH=/mnt/hexinas/hexi-media/files
DATABASE_PATH=/mnt/hexinas/hexi-media/hexi.db
PORT=4100
ENVIRONMENT=development
CORS_ORIGIN=*
CDN_BASE_URL=/api/v1/cdn
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_FROM=Gallery <noreply@example.com>
# SMTP_PASS=set-this-value
MAGIC_LINK_BASE_URL=http://localhost:4101

# OAuth - Google (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-domain/api/v1/auth/oauth/google/callback

# OAuth - Apple (optional)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# OAuth - Dashboard redirect (optional, defaults to API origin)
# DASHBOARD_URL=https://your-dashboard-domain

# 4sure OIDC Auth (optional)
# FOURSURE_CLIENT_ID=4s_xxxxxxxxx
# FOURSURE_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# FOURSURE_ISSUER=https://your-4sure-instance.example.com
