{
  "name": "@hexi/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute hexi-db --local --file=./migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute hexi-db --remote --file=./migrations/0001_initial.sql",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "wrangler": "^3.91.0",
    "typescript": "~5.6.2"
  }
}
