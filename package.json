{
  "name": "hexi-photo-gallery",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:lib": "turbo run build:lib",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "packageManager": "npm@10.9.4",
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
