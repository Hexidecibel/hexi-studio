#!/usr/bin/env bash
set -e

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOG_DIR="$ROOT_DIR/.dev-logs"
PID_DIR="$ROOT_DIR/.dev-pids"

mkdir -p "$LOG_DIR" "$PID_DIR"

# Detect network IP
NET_IP=$(hostname -I | awk '{print $1}')
if [ -z "$NET_IP" ]; then
  NET_IP="localhost"
fi

# Check if already running
if [ -f "$PID_DIR/worker.pid" ] && kill -0 "$(cat "$PID_DIR/worker.pid")" 2>/dev/null; then
  echo "Dev environment is already running. Use bin/dev-restart to restart."
  exit 1
fi

echo "Starting Hexi Gallery Cloud dev environment..."

# Run D1 migration (local)
echo "  Applying D1 migrations..."
cd "$ROOT_DIR/apps/worker"
npx wrangler d1 execute hexi-db --local --file=./migrations/0001_initial.sql 2>&1 | tail -1

# Start Worker API (bind to 0.0.0.0)
echo "  Starting Worker API (port 8790)..."
cd "$ROOT_DIR/apps/worker"
npx wrangler dev --port 8790 --ip 0.0.0.0 > "$LOG_DIR/worker.log" 2>&1 &
echo $! > "$PID_DIR/worker.pid"

# Start Dashboard (bind to 0.0.0.0)
echo "  Starting Dashboard (port 5174)..."
cd "$ROOT_DIR/apps/dashboard"
npx vite --port 5174 --host 0.0.0.0 > "$LOG_DIR/dashboard.log" 2>&1 &
echo $! > "$PID_DIR/dashboard.pid"

# Wait a moment for servers to start
sleep 3

echo ""
echo "Dev environment started!"
echo ""
echo "  Dashboard:  http://${NET_IP}:5174"
echo "  Worker API: http://${NET_IP}:8790"
echo "  Health:     http://${NET_IP}:8790/health"
echo ""
echo "Logs:"
echo "  Worker:     tail -f .dev-logs/worker.log"
echo "  Dashboard:  tail -f .dev-logs/dashboard.log"
echo ""
echo "Stop with: bin/dev-stop"
