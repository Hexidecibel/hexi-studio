#!/usr/bin/env bash

echo "Hexi Gallery Status"
echo "==================="

# API
if lsof -ti:4100 >/dev/null 2>&1; then
  PID=$(lsof -ti:4100 | head -1)
  echo "API:        RUNNING (pid $PID, port 4100)"
else
  echo "API:        STOPPED"
fi

# Dashboard
if lsof -ti:4101 >/dev/null 2>&1; then
  PID=$(lsof -ti:4101 | head -1)
  echo "Dashboard:  RUNNING (pid $PID, port 4101)"
else
  echo "Dashboard:  STOPPED"
fi

echo ""
IP=$(hostname -I | awk '{print $1}')
echo "LAN IP: $IP"
echo "Dashboard:  http://${IP}:4101"
echo "API:        http://${IP}:4100"
